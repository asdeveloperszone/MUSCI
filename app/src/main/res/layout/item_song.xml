<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardSong"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="5dp"
    app:cardBackgroundColor="@color/card_bg"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical">

        <!-- Playing indicator bar -->
        <View
            android:id="@+id/viewPlayingIndicator"
            android:layout_width="3dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_playing_indicator"
            android:visibility="gone" />

        <!-- Album Art -->
        <FrameLayout
            android:layout_width="58dp"
            android:layout_height="58dp">

            <ImageView
                android:id="@+id/ivAlbumArt"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_music_note"
                android:background="@drawable/bg_album_art_mini" />

            <ImageView
                android:id="@+id/ivPlayingIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="bottom|end"
                android:src="@drawable/ic_play"
                android:background="@drawable/bg_playing_badge"
                android:padding="3dp"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Song Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginHorizontal="12dp">

            <TextView
                android:id="@+id/tvSongTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Song Title"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvArtistName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Artist Name"
                android:textColor="@color/red_light"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvAlbumName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Album Name"
                android:textColor="#66FFFFFF"
                android:textSize="11sp"
                android:layout_marginTop="1dp"
                android:singleLine="true"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Duration -->
        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3:45"
            android:textColor="#55FFFFFF"
            android:textSize="11sp"
            android:fontFamily="sans-serif-light" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
