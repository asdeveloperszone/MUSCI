<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_appbar_gradient"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="8dp"
            android:paddingHorizontal="16dp">

            <!-- Title Row -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">

                <ImageView android:layout_width="28dp" android:layout_height="28dp"
                    android:src="@mipmap/ic_launcher" android:scaleType="centerCrop"/>

                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="MUSIC PLAYER"
                    android:textColor="@color/white" android:textSize="18sp"
                    android:textStyle="bold" android:letterSpacing="0.08"
                    android:fontFamily="sans-serif-condensed" android:layout_marginStart="10dp"/>

                <TextView android:id="@+id/tvSongCount"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 songs" android:textColor="#AAFFFFFF" android:textSize="12sp"
                    android:background="@drawable/bg_pill"
                    android:paddingHorizontal="8dp" android:paddingVertical="2dp"/>

                <ImageButton android:id="@+id/btnSort"
                    android:layout_width="34dp" android:layout_height="34dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_sort" android:background="@drawable/bg_icon_btn"
                    android:tint="@color/white" android:contentDescription="Sort"/>

                <ImageButton android:id="@+id/btnSettings"
                    android:layout_width="34dp" android:layout_height="34dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_settings" android:background="@drawable/bg_icon_btn"
                    android:tint="@color/white" android:contentDescription="Settings"/>

            </LinearLayout>

            <!-- Search -->
            <EditText android:id="@+id/etSearch"
                android:layout_width="match_parent" android:layout_height="38dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_search"
                android:drawableStart="@drawable/ic_search" android:drawablePadding="8dp"
                android:hint="Search songs, artists, albums..."
                android:textColorHint="#88FFFFFF" android:textColor="@color/white"
                android:textSize="13sp" android:paddingHorizontal="12dp"
                android:inputType="text" android:imeOptions="actionSearch"/>

            <!-- Tabs -->
            <HorizontalScrollView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="10dp"
                android:scrollbars="none">
                <LinearLayout android:layout_width="wrap_content"
                    android:layout_height="32dp" android:orientation="horizontal">

                    <TextView android:id="@+id/tabSongs"
                        android:layout_width="wrap_content" android:layout_height="match_parent"
                        android:text="Songs" android:textColor="@color/white"
                        android:textSize="13sp" android:textStyle="bold"
                        android:gravity="center" android:paddingHorizontal="16dp"
                        android:background="@drawable/bg_tab_active"/>

                    <TextView android:id="@+id/tabAlbums"
                        android:layout_width="wrap_content" android:layout_height="match_parent"
                        android:text="Albums" android:textColor="#AAFFFFFF"
                        android:textSize="13sp" android:gravity="center"
                        android:paddingHorizontal="16dp" android:layout_marginStart="8dp"
                        android:background="@drawable/bg_tab_inactive"/>

                    <TextView android:id="@+id/tabArtists"
                        android:layout_width="wrap_content" android:layout_height="match_parent"
                        android:text="Artists" android:textColor="#AAFFFFFF"
                        android:textSize="13sp" android:gravity="center"
                        android:paddingHorizontal="16dp" android:layout_marginStart="8dp"
                        android:background="@drawable/bg_tab_inactive"/>

                    <TextView android:id="@+id/tabFavorites"
                        android:layout_width="wrap_content" android:layout_height="match_parent"
                        android:text="❤ Favorites" android:textColor="#AAFFFFFF"
                        android:textSize="13sp" android:gravity="center"
                        android:paddingHorizontal="16dp" android:layout_marginStart="8dp"
                        android:background="@drawable/bg_tab_inactive"/>

                </LinearLayout>
            </HorizontalScrollView>

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:paddingBottom="76dp" android:paddingTop="8dp" android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"/>

    <!-- Mini Player -->
    <LinearLayout android:id="@+id/miniPlayer"
        android:layout_width="match_parent" android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_mini_player"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp" android:gravity="center_vertical"
        android:elevation="12dp" android:visibility="gone">

        <ImageView android:id="@+id/ivMiniArt"
            android:layout_width="44dp" android:layout_height="44dp"
            android:scaleType="centerCrop" android:src="@drawable/ic_music_note"
            android:background="@drawable/bg_album_art_mini"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:layout_marginHorizontal="10dp">
            <TextView android:id="@+id/tvMiniTitle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Song Title" android:textColor="@color/white"
                android:textSize="13sp" android:textStyle="bold"
                android:singleLine="true" android:ellipsize="marquee"/>
            <TextView android:id="@+id/tvMiniArtist"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Artist" android:textColor="#BBFFFFFF"
                android:textSize="11sp" android:singleLine="true"/>
        </LinearLayout>

        <ImageButton android:id="@+id/btnMiniPlayPause"
            android:layout_width="36dp" android:layout_height="36dp"
            android:src="@drawable/ic_play"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white" android:contentDescription="Play Pause"/>

        <ImageButton android:id="@+id/btnMiniNext"
            android:layout_width="36dp" android:layout_height="36dp"
            android:src="@drawable/ic_skip_next"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white" android:contentDescription="Next"/>

        <ImageButton android:id="@+id/btnMiniClose"
            android:layout_width="32dp" android:layout_height="32dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#AAFFFFFF" android:layout_marginStart="4dp"
            android:contentDescription="Close"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
