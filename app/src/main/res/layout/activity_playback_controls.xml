<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="16dp" android:background="@drawable/bg_appbar_gradient">
        <ImageButton android:id="@+id/btnPbBack"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white" android:contentDescription="Back"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="PLAYBACK CONTROLS" android:textColor="@color/white"
            android:textSize="18sp" android:textStyle="bold"
            android:fontFamily="sans-serif-condensed" android:layout_marginStart="12dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Speed -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_speed_outline" android:tint="@color/red_primary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="  PLAYBACK SPEED" android:textColor="@color/red_primary"
                    android:textSize="12sp" android:letterSpacing="0.1"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="12dp">
                <LinearLayout android:id="@+id/speedContainer"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="12dp"/>
            </androidx.cardview.widget.CardView>

            <!-- Pitch -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginTop="20dp" android:layout_marginBottom="8dp">
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_pitch" android:tint="@color/red_primary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="  PITCH CONTROL" android:textColor="@color/red_primary"
                    android:textSize="12sp" android:letterSpacing="0.1"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Change pitch without changing speed"
                        android:textColor="#88FFFFFF" android:textSize="12sp"
                        android:layout_marginBottom="12dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_pitch" android:tint="#55FFFFFF"/>
                        <SeekBar android:id="@+id/seekPitch"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginHorizontal="12dp"
                            android:progressTint="@color/red_primary" android:thumbTint="@color/white"/>
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_pitch" android:tint="@color/red_primary"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvPitchValue"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="1.00x" android:textColor="@color/red_primary"
                        android:textSize="16sp" android:textStyle="bold"
                        android:gravity="center" android:layout_marginTop="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Crossfade -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginTop="20dp" android:layout_marginBottom="8dp">
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_crossfade" android:tint="@color/red_primary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="  CROSSFADE" android:textColor="@color/red_primary"
                    android:textSize="12sp" android:letterSpacing="0.1"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Smooth fade between songs"
                        android:textColor="#88FFFFFF" android:textSize="12sp"
                        android:layout_marginBottom="12dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_crossfade" android:tint="#55FFFFFF"/>
                        <SeekBar android:id="@+id/seekCrossfade"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginHorizontal="12dp"
                            android:progressTint="@color/red_primary" android:thumbTint="@color/white"/>
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_crossfade" android:tint="@color/red_primary"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvCrossfadeValue"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Off" android:textColor="@color/red_primary"
                        android:textSize="16sp" android:textStyle="bold"
                        android:gravity="center" android:layout_marginTop="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
