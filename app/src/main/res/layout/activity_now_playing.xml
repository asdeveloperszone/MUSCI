<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Blur background -->
    <ImageView android:id="@+id/ivBlurBg"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:scaleType="centerCrop" android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Back -->
    <ImageButton android:id="@+id/btnBack"
        android:layout_width="40dp" android:layout_height="40dp"
        android:layout_marginStart="12dp" android:layout_marginTop="12dp"
        android:src="@drawable/ic_arrow_back"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="@color/white" android:contentDescription="Back"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>

    <!-- Now Playing label -->
    <TextView android:id="@+id/tvNowPlayingLabel"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:text="NOW PLAYING" android:textColor="#AAFFFFFF"
        android:textSize="11sp" android:letterSpacing="0.15"
        android:gravity="center" android:fontFamily="sans-serif-condensed"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintEnd_toStartOf="@id/btnBgToggle"/>

    <!-- BG Toggle -->
    <ImageButton android:id="@+id/btnBgToggle"
        android:layout_width="36dp" android:layout_height="36dp"
        android:layout_marginTop="14dp"
        android:src="@drawable/ic_palette"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Background Style"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnFavorite"/>

    <!-- Favorite -->
    <ImageButton android:id="@+id/btnFavorite"
        android:layout_width="36dp" android:layout_height="36dp"
        android:layout_marginTop="14dp"
        android:src="@drawable/ic_favorite_border"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Favorite"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnClose"/>

    <!-- Close -->
    <ImageButton android:id="@+id/btnClose"
        android:layout_width="40dp" android:layout_height="40dp"
        android:layout_marginEnd="12dp" android:layout_marginTop="12dp"
        android:src="@drawable/ic_close"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="#FFAAAAAA" android:contentDescription="Stop"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Album Art -->
    <ImageView android:id="@+id/ivAlbumArt"
        android:layout_width="0dp" android:layout_height="0dp"
        android:layout_marginHorizontal="40dp" android:layout_marginTop="8dp"
        android:scaleType="centerCrop" android:src="@drawable/ic_music_note"
        android:background="@drawable/bg_album_art_large" android:elevation="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintBottom_toTopOf="@id/tvTitle"/>

    <!-- Title -->
    <TextView android:id="@+id/tvTitle"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp" android:layout_marginTop="12dp"
        android:text="Song Title" android:textColor="@color/white"
        android:textSize="19sp" android:textStyle="bold"
        android:singleLine="true" android:ellipsize="marquee"
        android:marqueeRepeatLimit="marquee_forever"
        android:fontFamily="sans-serif-condensed"
        app:layout_constraintTop_toBottomOf="@id/ivAlbumArt"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <TextView android:id="@+id/tvArtist"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp" android:layout_marginTop="2dp"
        android:text="Artist" android:textColor="@color/red_light"
        android:textSize="13sp" android:singleLine="true"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <TextView android:id="@+id/tvAlbum"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp" android:layout_marginTop="1dp"
        android:text="Album" android:textColor="#66FFFFFF"
        android:textSize="11sp" android:singleLine="true"
        app:layout_constraintTop_toBottomOf="@id/tvArtist"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Extra buttons: EQ | Speed | Queue | Info -->
    <LinearLayout android:id="@+id/extraBtnsRow"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="20dp" android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvAlbum"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <ImageButton android:id="@+id/btnEqualizer"
            android:layout_width="30dp" android:layout_height="30dp"
            android:src="@drawable/ic_equalizer"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#AAFFFFFF" android:contentDescription="Equalizer"/>
        <ImageButton android:id="@+id/btnSpeed"
            android:layout_width="30dp" android:layout_height="30dp"
            android:layout_marginStart="6dp"
            android:src="@drawable/ic_speed_outline"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#AAFFFFFF" android:contentDescription="Speed"/>
        <ImageButton android:id="@+id/btnQueue"
            android:layout_width="30dp" android:layout_height="30dp"
            android:layout_marginStart="6dp"
            android:src="@drawable/ic_queue"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#AAFFFFFF" android:contentDescription="Queue"/>
        <ImageButton android:id="@+id/btnSongInfo"
            android:layout_width="30dp" android:layout_height="30dp"
            android:layout_marginStart="6dp"
            android:src="@drawable/ic_info"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#AAFFFFFF" android:contentDescription="Song Info"/>
    </LinearLayout>

    <!-- Visualizer -->
    <com.asdeveloperszone.musicplayer.VisualizerView
        android:id="@+id/visualizer"
        android:layout_width="0dp" android:layout_height="48dp"
        android:layout_marginHorizontal="24dp" android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/extraBtnsRow"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <!-- SeekBar -->
    <SeekBar android:id="@+id/seekBar"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp" android:layout_marginTop="2dp"
        android:progressTint="@color/red_primary" android:thumbTint="@color/white"
        app:layout_constraintTop_toBottomOf="@id/visualizer"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <TextView android:id="@+id/tvCurrentTime"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginStart="24dp" android:text="0:00"
        android:textColor="#88FFFFFF" android:textSize="11sp"
        app:layout_constraintTop_toBottomOf="@id/seekBar"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView android:id="@+id/tvTotalTime"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginEnd="24dp" android:text="0:00"
        android:textColor="#88FFFFFF" android:textSize="11sp"
        app:layout_constraintTop_toBottomOf="@id/seekBar"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Controls -->
    <ImageButton android:id="@+id/btnShuffle"
        android:layout_width="36dp" android:layout_height="36dp"
        android:layout_marginStart="16dp" android:layout_marginBottom="16dp"
        android:src="@drawable/ic_shuffle"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="@color/white" android:alpha="0.4" android:contentDescription="Shuffle"
        app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCurrentTime"/>

    <ImageButton android:id="@+id/btnRewind"
        android:layout_width="36dp" android:layout_height="36dp"
        android:src="@drawable/ic_rewind"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="@color/white" android:contentDescription="Rewind"
        app:layout_constraintTop_toTopOf="@id/btnShuffle"
        app:layout_constraintBottom_toBottomOf="@id/btnShuffle"
        app:layout_constraintStart_toEndOf="@id/btnShuffle"
        app:layout_constraintEnd_toStartOf="@id/btnPrevious"/>

    <ImageButton android:id="@+id/btnPrevious"
        android:layout_width="44dp" android:layout_height="44dp"
        android:src="@drawable/ic_skip_previous"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="@color/white" android:contentDescription="Previous"
        app:layout_constraintTop_toTopOf="@id/btnShuffle"
        app:layout_constraintBottom_toBottomOf="@id/btnShuffle"
        app:layout_constraintStart_toEndOf="@id/btnRewind"
        app:layout_constraintEnd_toStartOf="@id/btnPlayPause"/>

    <ImageButton android:id="@+id/btnPlayPause"
        android:layout_width="64dp" android:layout_height="64dp"
        android:src="@drawable/ic_play" android:background="@drawable/bg_play_button"
        android:tint="@color/white" android:contentDescription="Play Pause"
        app:layout_constraintTop_toTopOf="@id/btnShuffle"
        app:layout_constraintBottom_toBottomOf="@id/btnShuffle"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <ImageButton android:id="@+id/btnNext"
        android:layout_width="44dp" android:layout_height="44dp"
        android:src="@drawable/ic_skip_next"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="@color/white" android:contentDescription="Next"
        app:layout_constraintTop_toTopOf="@id/btnShuffle"
        app:layout_constraintBottom_toBottomOf="@id/btnShuffle"
        app:layout_constraintStart_toEndOf="@id/btnPlayPause"
        app:layout_constraintEnd_toStartOf="@id/btnForward"/>

    <ImageButton android:id="@+id/btnForward"
        android:layout_width="36dp" android:layout_height="36dp"
        android:src="@drawable/ic_forward"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="@color/white" android:contentDescription="Forward"
        app:layout_constraintTop_toTopOf="@id/btnShuffle"
        app:layout_constraintBottom_toBottomOf="@id/btnShuffle"
        app:layout_constraintStart_toEndOf="@id/btnNext"
        app:layout_constraintEnd_toStartOf="@id/btnRepeat"/>

    <ImageButton android:id="@+id/btnRepeat"
        android:layout_width="36dp" android:layout_height="36dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_repeat"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="@color/white" android:alpha="0.4" android:contentDescription="Repeat"
        app:layout_constraintTop_toTopOf="@id/btnShuffle"
        app:layout_constraintBottom_toBottomOf="@id/btnShuffle"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
